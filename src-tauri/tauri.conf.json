{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lysmata",
  "version": "0.1.0",
  "identifier": "com.fxai.lysmata",
  "build": {
    "beforeDevCommand": "bun run dev:all",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:sidecar && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lysmata",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": ["bin/hono-sidecar"],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist",
      "dmg": {
        "windowSize": {
          "width": 440,
          "height": 340
        },
        "appPosition": {
          "x": 110,
          "y": 200
        },
        "applicationFolderPosition": {
          "x": 320,
          "y": 200
        }
      }
    }
  }
}
