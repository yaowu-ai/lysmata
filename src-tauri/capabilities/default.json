{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "http:default",
    "http:allow-fetch"
  ]
}
