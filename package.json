{
  "name": "lysmata",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "src-api"
  ],
  "scripts": {
    "dev": "vite",
    "dev:api": "bun run --hot src-api/src/index.ts",
    "dev:all": "concurrently \"bun run dev\" \"bun run dev:api\"",
    "build": "tsc && vite build",
    "build:sidecar": "bun run compile-sidecar.ts",
    "build:sidecar:x64": "SIDECAR_TARGET=x86_64-apple-darwin bun run build:sidecar",
    "build:cargo:x64": "cargo build --release --target x86_64-apple-darwin --manifest-path src-tauri/Cargo.toml",
    "build:dmg:x64": "bun run build:sidecar:x64 && bun run build:cargo:x64 && bun run build:dmg:dev -- --target=x86_64-apple-darwin",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:dmg": "CI=true tauri build --bundles dmg",
    "build:dmg:dev": "TAURI_SKIP_NOTARIZATION=true CI=true tauri build --bundles dmg"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.90.21",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "hono": "^4.11.9",
    "lucide-react": "^0.574.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.0",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "bun-types": "^1.3.9",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.0.4"
  }
}
